{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "PopMedia",
  "version": "0.1.0",
  "identifier": "com.popmedia.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "vite",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "PopMedia",
        "label": "main",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "backgroundColor": "#1a1a1a",
        "visible": false
      },
      {
        "label": "splashscreen",
        "title": "PopMedia",
        "width": 400,
        "height": 300,
        "resizable": false,
        "center": true,
        "decorations": false,
        "transparent": false,
        "backgroundColor": "#1a1a1a",
        "alwaysOnTop": true,
        "visible": true,
        "url": "/splashscreen.html"
      }
    ],
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPLOCALDATA/assets/**",
          "$APPLOCALDATA/**/*",
          "**/*"
        ]
      },
      "csp": "default-src 'self'; img-src 'self' data: blob: asset: https://asset.localhost; media-src 'self' data: blob: asset: https://asset.localhost; script-src 'self'; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
